layout {

    focus-ring {
        active-color   "#e46771"
        inactive-color "#291416"
        urgent-color   "#fd4663"
    }

    border {
        active-color   "#e46771"
        inactive-color "#291416"
        urgent-color   "#fd4663"
    }

    shadow {
        color "#29141670"
    }

    tab-indicator {
        active-color   "#e46771"
        inactive-color "#8d0c16"
        urgent-color   "#fd4663"
    }

    insert-hint {
        color "#e4677180"
    }
}

recent-windows {
    highlight {
        active-color "#e46771"
        urgent-color "#fd4663"
    }
}
